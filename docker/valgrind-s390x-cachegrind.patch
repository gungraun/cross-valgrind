 #elif defined(VGA_mips32) || defined(VGA_nanomips)
 
diff --git a/coregrind/m_cache.c b/coregrind/m_cache.c
index c0ec59b19..f930837ef 100644
--- a/coregrind/m_cache.c
+++ b/coregrind/m_cache.c
@@ -607,12 +607,31 @@ get_cache(UInt level, VexCacheKind kind)
    return VEX_CACHE_INIT(kind, level + 1, size, line_size, assoc);
 }
 
+static Bool
+cache_values_are_sensible(const VexCache *cache)
+{
+   if (cache->sizeB == 0 || cache->line_sizeB == 0 || cache->assoc == 0)
+      return False;
+
+   if (cache->sizeB <= cache->line_sizeB)
+      return False;
+
+   if (cache->assoc > cache->sizeB / cache->line_sizeB)
+      return False;
+
+   if (VG_(log2)(cache->line_sizeB) == -1)
+      return False;
+
+   return True;
+}
+
 static Bool
 get_cache_info(VexArchInfo *vai)
 {
    VexCacheInfo *ci = &vai->hwcache_info;
 
    ci->icaches_maintain_coherence = True;
+   ci->caches = NULL;
 
    UInt level, cache_kind, info, i;
    ULong topology = ecag(0, 0, 0);   // get summary
@@ -636,6 +655,9 @@ get_cache_info(VexArchInfo *vai)
       }
    }
 
+   if (ci->num_caches == 0)
+      return False;
+
    ci->caches = VG_(malloc)("m_cache", ci->num_caches * sizeof *ci->caches);
 
    i = 0;
@@ -661,6 +683,15 @@ get_cache_info(VexArchInfo *vai)
          break;
       }
    }
+
+   for (i = 0; i < ci->num_caches; i++) {
+      if (!cache_values_are_sensible(&ci->caches[i])) {
+         VG_(debugLog)(1, "cache",
+                       "warning: s390x ECAG cache values are not sensible\n");
+         return False;
+      }
+   }
+
    return True;
 }
 
