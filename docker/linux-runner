#!/usr/bin/env bash

set -e

# shellcheck disable=SC1091
. /base-runner.sh

# Return true if the log level is debug
is_debug() {
    [[ -n "$CROSS_DEBUG" ]]
}

# If debugging is activated, execute the given arguments in a subshell
if_debug() {
    if is_debug; then
        "$@"
    else
        true
    fi
}

# If debugging is not set, execute the given arguments in a subshell
if_not_debug() {
    if ! is_debug; then
        "$@"
    else
        true
    fi
}

quote() {
    local value=$1
    printf "'%s'" "${value//\'/\'\\\'\'}"
}

rust_bin_path() {
    printf '%s/bin\n' "${CROSS_RUST_SYSROOT:-/rust}"
}

project_mount() {
    local mount=

    # Mount the Docker filesystem that contains the cwd so dbclient can cd to
    # the same absolute path inside the QEMU guest.
    if command -v findmnt >/dev/null 2>&1; then
        mount=$(findmnt --raw --noheadings --target "$(pwd)" --output TARGET 2>/dev/null || true)
    fi

    if [[ -z "$mount" || "$mount" == "/" ]]; then
        mount=$(pwd)
    fi

    printf '%s\n' "$mount"
}

is_safe_docker_mount() {
    local path=$1 fstype=$2

    [[ -d "$path" ]] || return 1

    case "$path" in
    / | /dev | /dev/* | /proc | /proc/* | /sys | /sys/* | /run | /run/* | /etc/hostname | /etc/hosts | /etc/resolv.conf)
        return 1
        ;;
    esac

    case "$fstype" in
    overlay | proc | sysfs | tmpfs | devtmpfs | devpts | cgroup | cgroup2 | mqueue | securityfs | debugfs | tracefs | fusectl | binfmt_misc)
        return 1
        ;;
    esac

    return 0
}

emit_mount_spec() {
    local tag=$1 path=$2

    [[ -n "$path" && -d "$path" ]] || return 0
    # Deduplicate by guest path so semantic tags win over generated tags.
    [[ -z "${mount_paths[$path]:-}" ]] || return 0

    printf '%s:%s\n' "$tag" "$path"
    mount_paths[$path]=1
}

collect_mount_specs() {
    local path fstype tag index=0

    declare -A mount_paths=()

    # Add stable tags for paths the runner or cross commonly reference.
    emit_mount_spec project "$(project_mount)"
    emit_mount_spec target "${CARGO_TARGET_DIR:-/target}"
    emit_mount_spec opt /opt
    emit_mount_spec tmp /tmp
    emit_mount_spec cargo "${CARGO_HOME:-/cargo}"
    emit_mount_spec rust "${CROSS_RUST_SYSROOT:-/rust}"
    emit_mount_spec xargo "${XARGO_HOME:-/xargo}"

    if command -v findmnt >/dev/null 2>&1; then
        # Keep nested Docker mounts: /cargo alone would not include a separate
        # /cargo/bin mount, so forwarding both preserves Docker's view.
        while read -r path fstype; do
            if is_safe_docker_mount "$path" "$fstype"; then
                tag="mount${index}"
                emit_mount_spec "$tag" "$path"
                index=$((index + 1))
            fi
        done < <(findmnt --raw --noheadings --output TARGET,FSTYPE 2>/dev/null || true)
    fi
}

run_dbclient() {
    local key value remote

    local max_attempts=3
    local attempt=1
    local log_lines=0
    local status=0
    local envs=("PATH=/opt/valgrind/bin:/usr/sbin:/usr/bin:/sbin:/bin:$(rust_bin_path)")

    for key in LD_LIBRARY_PATH RUST_TEST_THREADS TERM; do
        local value="${!key}"
        if [[ -n "$value" ]]; then
            envs+=("${key}=${value}")
        fi
    done

    while IFS='=' read -r key value; do
        case "$key" in
        # Can subtly break the test/bench/run. They make sense on the host but
        # not in the qemu image.
        CARGO_TARGET_*_RUNNER | CARGO_TARGET_*_LINKER | CARGO_TARGET_*_RUSTFLAGS)
            continue
            ;;
        CARGO_*) envs+=("${key}=${value}") ;;
        esac
    done < <(printenv)

    remote="cd $(quote "$(pwd)") && env"

    for env in "${envs[@]}"; do
        remote+=" $(quote "$env")"
    done

    remote+=" ${CROSS_VALGRIND}"

    for arg in "$@"; do
        remote+=" $(quote "$arg")"
    done

    while ((attempt <= max_attempts)); do
        log_lines=$(wc -l <"${LOG}" 2>/dev/null || printf '0')

        set +e
        dbclient "${tty_flag}" -p 10022 -y -y root@localhost "$remote"
        status=$?
        set -e

        if ((status == 0)); then
            return 0
        fi

        if tail -n "+$((log_lines + 1))" "${LOG}" | grep -q 'Timeout before auth'; then
            if ((attempt < max_attempts)); then
                echo "Retrying dbclient after dropbear auth timeout (${attempt}/${max_attempts})..." >&2
                sleep 1
                attempt=$((attempt + 1))
                continue
            fi
        fi

        return "${status}"
    done
}

if_debug set -x

LOG=/target/tmp/qemu.log
LOCK=/run/lock/qemu.lock

mkdir -p "/target/tmp" "/run/lock"

# arch in the rust target
arch="${1}"
shift

if [[ -z "${CROSS_RUNNER}" ]]; then
    if [[ -n "${CROSS_VALGRIND}" ]]; then
        CROSS_RUNNER=qemu-system
    elif is_native_binary "${arch}"; then
        CROSS_RUNNER=native
    else
        CROSS_RUNNER=qemu-user
    fi
fi

# Ensure that the correct prefix is set even if the user has cleared the env.
# `@DEFAULT_QEMU_LD_PREFIX@` is replaced during image build.
export QEMU_LD_PREFIX=${QEMU_LD_PREFIX:-@DEFAULT_QEMU_LD_PREFIX@}

if_debug echo -n "linux-runner: args: "
if_debug echo "${@}"

qarch=$(qemu_arch "${arch}")

case "${CROSS_RUNNER}" in
native)
    exec "${@}"
    ;;
qemu-user)
    exec "qemu-${qarch}" "${@}"
    ;;
qemu-system)
    true
    ;;
*)
    echo "Invalid runner: \"${CROSS_RUNNER}\""
    echo "Valid runners are: qemu-system"
    exit 1
    ;;
esac

n="$(nproc)"
memory=1G
opt=()
driver9p="virtio-9p-pci"
drivernet="virtio-net-pci"
kernel_args=()

# select qemu parameters
case "${arch}" in
aarch64 | aarch64_be)
    # 8 is the max number of cpu supported by qemu-aarch64
    n=$((n > 8 ? 8 : n))
    opt=(-machine virt -cpu cortex-a57)
    ;;
armv7hf)
    opt=(-machine virt)
    driver9p="virtio-9p-device"
    drivernet="virtio-net-device"
    ;;
i686)
    kernel_args=(console=ttyS0)
    ;;
mips | mipsel)
    # Using the console=... here to force the placement of it before the init
    # arguments. This option is added to the kernel cmdline but incorrectly
    # after the init arguments, making it effectively part of the init
    # arguments.
    kernel_args=(nokaslr "console=ttyS0,38400n8r")
    n=1
    ;;
mips64el)
    opt=(-M malta -cpu MIPS64R2-generic)
    kernel_args=(nokaslr "console=ttyS0,38400n8r")
    n=1
    ;;
powerpc)
    kernel_args=(console=ttyPZ0)
    n=1
    ;;
riscv64)
    opt=(-machine virt)
    ;;
powerpc64 | powerpc64le)
    opt=(--nodefaults -serial stdio)
    kernel_args=(console=hvc0)
    ;;
s390x)
    n=1
    driver9p="virtio-9p-ccw"
    drivernet="virtio-net-ccw"
    ;;
x86_64)
    kernel_args=(console=ttyS0)
    ;;
esac

(
    flock -n 200 || exit 0

    echo Booting QEMU virtual machine with "$n" cpus...

    # Do not use shorthand -nic syntax. It fails for example with qemu-system-arm
    QEMU_CMD=(
        "qemu-system-${qarch}"
        -m "${memory}"
        -smp "${n}"
        -nographic
        -monitor none
        -netdev "user,id=net0,hostfwd=tcp::10022-:22,ipv6=off"
        -device "${drivernet},netdev=net0"
        -kernel /qemu/kernel
        -initrd /qemu/initrd.gz
        "${opt[@]}"
    )

    counter=0
    init_args=()
    readarray -t mount_specs < <(collect_mount_specs)
    for mount in "${mount_specs[@]}"; do
        IFS=: read -r tag path <<<"$mount"
        device="${driver9p},fsdev=fs${counter},mount_tag=$tag"

        case "${arch}" in
        mips | mipsel | mips64el)
            # The Malta guest kernel only has IRQ mappings for PCI slots
            # 0x12-0x15. VGA and virtio-net take 0x12 and 0x13, so pack 9p
            # devices as functions on the remaining routed slots.
            slot=$((0x14 + counter / 8))
            function=$((counter % 8))
            if ((slot > 0x15)); then
                echo "Too many 9p mounts for MIPS Malta" >&2
                exit 1
            fi

            printf -v addr '0x%x.%x' "${slot}" "${function}"
            device+=",addr=${addr}"
            if ((function == 0)); then
                # See qemu-system-mips64el -device virtio-9p-pci,help
                device+=",multifunction=on"
            fi
            ;;
        esac

        QEMU_CMD+=(-fsdev "local,id=fs${counter},path=${path},security_model=mapped")
        QEMU_CMD+=(-device "${device}")

        init_args+=(-m "$mount")
        counter=$((++counter))

    done

    if ((${#init_args[@]})); then
        kernel_args+=(--)
        kernel_args+=("${init_args[@]}")
    fi

    if ((${#kernel_args[@]})); then
        append="${kernel_args[*]}"
        QEMU_CMD+=(-append "$append")
    fi

    printf "" >"${LOG}"
    if is_debug; then
        ("${QEMU_CMD[@]}" 2>&1 | tee -a "${LOG}") &
    else
        ("${QEMU_CMD[@]}" >>"${LOG}" 2>&1) &
    fi
    qemu_pid=$!

    # Wait for qemu to print dropbear's final 'Not backgrounding' message or until
    # the timeout is reached
    ticks=0
    timeout=240
    while true; do
        if ! kill -0 "$qemu_pid" 2>/dev/null; then

            echo -e "\nStarting qemu failed:\n"
            if_not_debug echo "Set the environment variable CROSS_DEBUG=1 to debug"
            if_not_debug echo "Last 100 lines of qemu output:"
            if_not_debug tail -n 100 "${LOG}"

            exit 1
        elif tail -10 "$LOG" | grep -q -e '---\[ end Kernel panic'; then
            kill -9 $qemu_pid

            echo -e "\nStarting qemu failed:\n"
            if_not_debug echo "Set the environment variable CROSS_DEBUG=1 to debug"
            if_not_debug echo "Last 100 lines of qemu output:"
            if_not_debug tail -n 100 "${LOG}"

            exit 1
        elif tail -10 "$LOG" | grep -q "Not backgrounding"; then
            break
        elif ((ticks >= timeout)); then
            kill -9 $qemu_pid

            echo "Qemu is not ready after ${ticks} seconds..."

            if_not_debug echo "Set the environment variable CROSS_DEBUG=1 to debug"
            if_not_debug echo "Last 100 lines of qemu output:"
            if_not_debug tail -n 100 "${LOG}"

            exit 1
        else
            : # do nothing
        fi

        sleep 0.5
        _=$((ticks++))
    done

    echo "Booted in $((ticks / 2)) seconds"

) 200>"${LOCK}"

if [[ -t 1 ]] && [[ -t 2 ]]; then
    tty_flag='-t'
else
    tty_flag='-T'
fi

if [[ -n "${CROSS_VALGRIND}" || -n "$*" ]]; then
    # shellcheck disable=2086
    run_dbclient "$@"
fi

exit 0
